{
  "name": "bards-tale-9-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite --config client/vite.config.ts",
    "dev:server": "tsx watch --env-file=.env server/src/index.ts",
    "build": "npm run build:server && npm run build:client",
    "build:client": "vite build --config client/vite.config.ts",
    "build:server": "tsc -p server/tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx --env-file=.env server/src/db/seed.ts",
    "start": "node dist/server/server/src/index.js"
  },
  "dependencies": {
    "@neondatabase/neon-js": "^0.2.0-beta.1",
    "fastify": "^5.2.1",
    "jose": "^6.2.2",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.174.0"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@types/three": "^0.174.0",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.2",
    "jsdom": "^26.0.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vite": "^6.2.2",
    "vitest": "^3.0.8"
  }
}
